<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_update_dialog"
        android:orientation="vertical"
        android:padding="20dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@drawable/bg_update_header_strip" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/updateDialogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Update"
                    android:textColor="#F5F7FF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/updateDialogVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Version: 1.0.1 (2)"
                    android:textColor="#C2C7E5"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/updateDialogBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_update_badge_optional"
                android:paddingLeft="14dp"
                android:paddingTop="8dp"
                android:paddingRight="14dp"
                android:paddingBottom="8dp"
                android:text="Optional"
                android:textColor="#EAF0FF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/updateDialogNotesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Release Notes"
            android:textColor="#8E95B7"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/updateDialogNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_update_notes_panel"
            android:lineSpacingExtra="3dp"
            android:minHeight="96dp"
            android:maxHeight="180dp"
            android:padding="16dp"
            android:text="Notes"
            android:textColor="#E8ECF9"
            android:textSize="15sp"
            android:fadeScrollbars="false"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical"
            android:scrollbarStyle="insideInset" />

        <LinearLayout
            android:id="@+id/updateDialogProgressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_update_notes_panel"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/updateDialogProgressLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Downloading"
                    android:textColor="#C7CBE1"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/updateDialogProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#95F3C4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/updateDialogProgressBar"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                app:indicatorColor="#8A78FF"
                app:trackColor="#30334F"
                app:trackThickness="8dp" />

            <TextView
                android:id="@+id/updateDialogProgressDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Preparing..."
                android:textColor="#9EA5C8"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/updateDialogError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_update_error_panel"
            android:padding="12dp"
            android:textColor="#FFB8C0"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/updateDialogTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tip"
            android:textColor="#7F86A9"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateDialogSecondaryAction"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_update_secondary_button"
                android:backgroundTint="@null"
                android:text="Later"
                android:textColor="#EAF0FF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="27dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateDialogPrimaryAction"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_update_primary_button"
                android:backgroundTint="@null"
                android:text="Update Now"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="27dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
